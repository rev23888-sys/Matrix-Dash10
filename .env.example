# ╔══════════════════════════════════════════════════════════════╗
# ║        MATRIX BOT DASHBOARD — Complete .env Guide           ║
# ║    Copy this to .env and fill in your real values           ║
# ╚══════════════════════════════════════════════════════════════╝

# ── DISCORD OAUTH (REQUIRED) ──────────────────────────────────
# Get from: https://discord.com/developers/applications
# → Your App → OAuth2 → copy Client ID and Client Secret
# → Add Redirect URI: https://YOUR_DOMAIN/api/auth/callback
BOT_CLIENT_ID="YOUR_DISCORD_CLIENT_ID"
BOT_CLIENT_SECRET="YOUR_DISCORD_CLIENT_SECRET"

# ── BOT CLIENT ID (public — used in frontend invite links) ────
NEXT_PUBLIC_BOT_CLIENT_ID="YOUR_DISCORD_CLIENT_ID"

# ── APP URL ───────────────────────────────────────────────────
# Local:      http://localhost:3000
# Production: https://your-dashboard.vercel.app
APP_URL="http://localhost:3000"

# ── BOT API ENDPOINT ──────────────────────────────────────────
# The URL of your running Discord bot's HTTP API server.
# The bot must expose REST endpoints at this URL.
# Local:      http://localhost:8080
# Production: https://api.yourdomain.com
#
# REQUIRED ENDPOINTS your bot must implement:
#   GET  /guilds/:id                    → returns GuildInfo or 404
#   GET  /guilds/:id/features/:feature  → returns feature config
#   POST /guilds/:id/features/:feature  → enable feature
#   DEL  /guilds/:id/features/:feature  → disable feature
#   PATCH /guilds/:id/features/:feature → update feature settings
#   POST /guilds/:id/settings           → save guild settings
#   GET  /guilds/:id/roles              → returns Role[]
#   GET  /guilds/:id/channels           → returns GuildChannel[]
NEXT_PUBLIC_API_ENDPOINT="http://localhost:8080"

# ── SESSION SECRET ────────────────────────────────────────────
# Any long random string. Generate:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET="change_this_to_a_long_random_secret_here"

# ── OPTIONAL: TOP.GG ─────────────────────────────────────────
# TOPGG_WEBHOOK_SECRET="your_topgg_secret"

# ── OPTIONAL: DATABASE ───────────────────────────────────────
# The dashboard itself is stateless — the BOT handles the DB.
# DATABASE_URL="mongodb+srv://user:pass@cluster.mongodb.net/matrix"

